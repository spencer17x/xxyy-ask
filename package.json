{
  "name": "xxyy-ask",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent:smoke": "node scripts/agent-smoke.mjs",
    "app:down": "docker compose down",
    "api:dev": "pnpm --filter @xxyy/api start",
    "app:dev": "node scripts/start-agent.mjs",
    "app:logs": "docker compose logs --follow --tail=200 api telegram",
    "app:restart": "docker compose restart api telegram",
    "app:status": "docker compose ps",
    "app:stop": "docker compose stop api telegram",
    "app:up": "docker compose up --detach --build",
    "check": "pnpm --filter @xxyy/web build && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm rag:evaluate",
    "docs:sync": "node scripts/sync-xxyy-docs.mjs",
    "docs:audit": "node scripts/audit-xxyy-docs.mjs",
    "docs:enrich:media": "node scripts/enrich-xxyy-media.mjs",
    "docs:sync:external": "node scripts/sync-xxyy-external-docs.mjs",
    "format": "prettier --write \"**/*.{ts,js,mjs,cjs,json,md,yml,yaml}\" \".vscode/*.json\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,cjs,json,md,yml,yaml}\" \".vscode/*.json\"",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "rag:ask": "pnpm --filter @xxyy/cli rag:ask",
    "rag:evaluate": "pnpm --filter @xxyy/cli rag:evaluate",
    "rag:feedback:backlog": "pnpm --filter @xxyy/cli rag:feedback:backlog",
    "rag:ingest": "pnpm --filter @xxyy/cli rag:ingest",
    "rag:knowledge:approve": "pnpm --filter @xxyy/cli rag:knowledge:approve",
    "rag:knowledge:import:telegram": "pnpm --filter @xxyy/cli rag:knowledge:import:telegram",
    "rag:knowledge:list": "pnpm --filter @xxyy/cli rag:knowledge:list",
    "rag:knowledge:publish": "pnpm --filter @xxyy/cli rag:knowledge:publish",
    "rag:knowledge:reject": "pnpm --filter @xxyy/cli rag:knowledge:reject",
    "rag:migrate": "pnpm --filter @xxyy/cli rag:migrate",
    "rag:stats": "pnpm --filter @xxyy/cli rag:stats",
    "rag:sync:x": "pnpm --filter @xxyy/cli rag:sync:x",
    "telegram:dev": "pnpm --filter @xxyy/telegram-bot start",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present --filter \"@xxyy/*\" typecheck",
    "web:dev": "pnpm --filter @xxyy/web dev",
    "x:scrape": "node scripts/fetch-usexxyy-posts.mjs"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  }
}
