{
  "name": "xxyy-ask",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "admin:token:create": "node scripts/create-knowledge-admin-token.mjs",
    "agent:smoke": "node scripts/agent-smoke.mjs",
    "app:down": "docker compose down",
    "api:dev": "pnpm --filter @xxyy/api start",
    "app:dev": "node scripts/start-agent.mjs",
    "app:logs": "docker compose logs --follow --tail=200 api telegram",
    "app:restart": "docker compose restart api telegram",
    "app:status": "docker compose ps",
    "app:stop": "docker compose stop api telegram",
    "app:up": "docker compose up --detach --build",
    "check": "pnpm --filter @xxyy/web build && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm rag:evaluate",
    "commit:check": "node scripts/validate-commit-message.mjs --message",
    "commit:range": "node scripts/validate-commit-range.mjs",
    "chain:control:migrate": "pnpm --filter @xxyy/chain-control-cli start migrate",
    "chain:ops:bootstrap": "pnpm --filter @xxyy/chain-operations-cli start bootstrap",
    "chain:ops:probe": "pnpm --filter @xxyy/chain-operations-cli start probe:snapshot",
    "chain:ops:validate": "pnpm --filter @xxyy/chain-operations-cli start validate",
    "chain:provision:apply": "pnpm --filter @xxyy/chain-control-cli start apply",
    "chain:provision:attest": "pnpm --filter @xxyy/chain-control-cli start attest",
    "chain:provision:plan": "pnpm --filter @xxyy/chain-control-cli start plan",
    "chain:provision:receipt": "pnpm --filter @xxyy/chain-control-cli start receipt",
    "chain:provision:verify": "pnpm --filter @xxyy/chain-control-cli start verify",
    "chain:worker:reconcile": "pnpm --filter @xxyy/chain-operations-cli start worker:reconcile",
    "chain:worker:retention": "pnpm --filter @xxyy/chain-operations-cli start worker:retention",
    "docs:sync": "node scripts/sync-xxyy-docs.mjs",
    "docs:audit": "node scripts/audit-xxyy-docs.mjs",
    "docs:enrich:media": "node scripts/enrich-xxyy-media.mjs",
    "docs:sync:external": "node scripts/sync-xxyy-external-docs.mjs",
    "format": "prettier --write \"**/*.{ts,js,mjs,cjs,json,md,yml,yaml}\" \".vscode/*.json\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,cjs,json,md,yml,yaml}\" \".vscode/*.json\"",
    "hook:pre-commit": "node scripts/validate-staged-files.mjs",
    "hook:pre-push": "node scripts/run-pre-push.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "rag:ask": "pnpm --filter @xxyy/cli rag:ask",
    "rag:evaluate": "pnpm --filter @xxyy/cli rag:evaluate",
    "rag:feedback:backlog": "pnpm --filter @xxyy/cli rag:feedback:backlog",
    "rag:ingest": "pnpm --filter @xxyy/cli rag:ingest",
    "rag:knowledge:approve": "pnpm --filter @xxyy/cli rag:knowledge:approve",
    "rag:knowledge:author:list": "pnpm --filter @xxyy/cli rag:knowledge:author:list",
    "rag:knowledge:author:trust": "pnpm --filter @xxyy/cli rag:knowledge:author:trust",
    "rag:knowledge:history": "pnpm --filter @xxyy/cli rag:knowledge:history",
    "rag:knowledge:import:telegram": "pnpm --filter @xxyy/cli rag:knowledge:import:telegram",
    "rag:knowledge:list": "pnpm --filter @xxyy/cli rag:knowledge:list",
    "rag:knowledge:publish": "pnpm --filter @xxyy/cli rag:knowledge:publish",
    "rag:knowledge:publication:work": "pnpm --filter @xxyy/cli rag:knowledge:publication:work",
    "rag:knowledge:reject": "pnpm --filter @xxyy/cli rag:knowledge:reject",
    "rag:knowledge:revise": "pnpm --filter @xxyy/cli rag:knowledge:revise",
    "rag:migrate": "pnpm --filter @xxyy/cli rag:migrate",
    "rag:refresh": "node scripts/rag-refresh.mjs",
    "rag:stats": "pnpm --filter @xxyy/cli rag:stats",
    "rag:sync:x": "pnpm --filter @xxyy/cli rag:sync:x",
    "telegram:dev": "pnpm --filter @xxyy/telegram-bot start",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present --filter \"@xxyy/*\" typecheck",
    "web:dev": "pnpm --filter @xxyy/web dev",
    "x:scrape": "node scripts/fetch-usexxyy-posts.mjs"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  }
}
