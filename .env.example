# LLM / embeddings
# REQUIRED for product RAG, API chat, CLI provider-backed ask/eval, and Telegram bot.
OPENAI_API_KEY=
OPENAI_MODEL=

# OPTIONAL. Defaults match OpenAI text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=1

# RAG behavior
# OPTIONAL.
RAG_TOP_K=6
RAG_ANSWER_PROVIDER=openai

# Database
# REQUIRED for product RAG retrieval, ingest, sync, stats, migrations, API chat, and Telegram bot.
# Use either DATABASE_URL, or POSTGRES_DB + POSTGRES_USER + POSTGRES_PASSWORD.
# DATABASE_URL=postgres://xxyy:replace_me_with_a_strong_password@localhost:5432/xxyy_ask
POSTGRES_DB=xxyy_ask
POSTGRES_USER=xxyy
POSTGRES_PASSWORD=replace_me_with_a_strong_password

# OPTIONAL when using POSTGRES_*; defaults are localhost:5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API service
# OPTIONAL service runtime.
# PORT=3000
# NODE_ENV=development
API_CORS_ORIGIN=
API_DEEP_HEALTH_TOKEN=
API_ENABLE_DEEP_HEALTH=
API_MAX_BODY_BYTES=65536
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY=false

# REQUIRED when chat auth is enabled.
# Chat auth defaults to enabled when NODE_ENV=production, and can be enabled with API_REQUIRE_CHAT_AUTH=true.
API_CHAT_AUTH_TOKEN=
API_CHAT_AUTH_TOKENS=

# OPTIONAL chat auth toggle.
API_REQUIRE_CHAT_AUTH=

# Telegram bot
# REQUIRED only when running pnpm run telegram:dev.
TELEGRAM_BOT_TOKEN=

# OPTIONAL Telegram runtime.
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_POLL_ERROR_RETRY_MS=3000
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_UPDATES_LIMIT=100

# Local app startup helper
# OPTIONAL.
XXYY_START_MODE=local
XXYY_SKIP_DOCKER=false

# X / Twitter update scraper
# OPTIONAL.
XXYY_X_MAX_PAGES=100
XXYY_X_PAGE_SIZE=40
XXYY_X_REQUEST_DELAY_MS=250

# Agent smoke test
# OPTIONAL.
API_SMOKE_BASE_URL=http://127.0.0.1:3000
API_SMOKE_PRODUCT_QUESTION=XXYY Pro 有哪些权益？
API_SMOKE_BOUNDARY_QUESTION=帮我查一下钱包余额

# Workspace resolution
# OPTIONAL advanced setting. Usually provided by pnpm; normally leave unset.
# INIT_CWD=/absolute/path/to/xxyy-ask
