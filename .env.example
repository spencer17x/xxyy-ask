# Core RAG / LLM
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=1

RAG_TOP_K=6
RAG_ANSWER_PROVIDER=openai

# Database
# DATABASE_URL=postgres://xxyy:replace_me_with_a_strong_password@localhost:5432/xxyy_ask
POSTGRES_DB=xxyy_ask
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=xxyy
POSTGRES_PASSWORD=replace_me_with_a_strong_password

# API service
# PORT=3000
# NODE_ENV=development
API_CORS_ORIGIN=
API_CHAT_AUTH_TOKEN=
API_CHAT_AUTH_TOKENS=
API_REQUIRE_CHAT_AUTH=
API_DEEP_HEALTH_TOKEN=
API_ENABLE_DEEP_HEALTH=
API_MAX_BODY_BYTES=65536
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY=false

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_POLL_ERROR_RETRY_MS=3000
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_UPDATES_LIMIT=100

# Local app startup helper
XXYY_START_MODE=local
XXYY_SKIP_DOCKER=false

# X / Twitter update scraper
XXYY_X_MAX_PAGES=100
XXYY_X_PAGE_SIZE=40
XXYY_X_REQUEST_DELAY_MS=250
