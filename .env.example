# Chat / planner
# REQUIRED for API chat, CLI provider-backed ask/eval, and Telegram bot.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPTIONAL Docker Compose override when OPENAI_BASE_URL points to a service on the host.
# Docker Desktop exposes the host as host.docker.internal.
COMPOSE_OPENAI_BASE_URL=

# Embeddings
# OPTIONAL overrides let embeddings use a different OpenAI-compatible provider.
# When blank, they fall back to OPENAI_API_KEY and OPENAI_BASE_URL.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_REQUEST_TIMEOUT_MS=30000
EVAL_JUDGE_MODEL=

# OPTIONAL answer-quality tracing. Disabled by default.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=xxyy-ask
QUALITY_TRACE_SAMPLE_RATE=
APP_REVISION=
OPENAI_MAX_RETRIES=1

# RAG behavior
# OPTIONAL.
RAG_TOP_K=6

# Database
# REQUIRED for product RAG retrieval, ingest, sync, stats, migrations, API chat, and Telegram bot.
# Use either DATABASE_URL, or POSTGRES_DB + POSTGRES_USER + POSTGRES_PASSWORD.
# DATABASE_URL=postgres://xxyy:replace_me_with_a_strong_password@localhost:5432/xxyy_ask
# OPTIONAL only for Docker Compose when using an external database reachable from containers.
# COMPOSE_DATABASE_URL=postgres://xxyy:replace_me_with_a_strong_password@db.example.com:5432/xxyy_ask
POSTGRES_DB=xxyy_ask
POSTGRES_USER=xxyy
POSTGRES_PASSWORD=replace_me_with_a_strong_password

# OPTIONAL when using POSTGRES_*; defaults are localhost:5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API service
# OPTIONAL service runtime.
# PORT=3000
# NODE_ENV=development
# Docker Compose binds to loopback by default. Use 0.0.0.0 only behind a firewall or reverse proxy.
APP_BIND_HOST=127.0.0.1
APP_PORT=3000
POSTGRES_BIND_HOST=127.0.0.1
API_CORS_ORIGIN=
API_ENABLE_DEEP_HEALTH=
API_MAX_BODY_BYTES=65536
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY=false

# Telegram bot
# REQUIRED only when running pnpm run telegram:dev.
TELEGRAM_BOT_TOKEN=

# OPTIONAL Telegram runtime.
TELEGRAM_PUBLIC_BASE_URL=
TELEGRAM_POLL_ERROR_RETRY_MS=3000
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_UPDATES_LIMIT=100

# Local app startup helper
# OPTIONAL.
XXYY_START_MODE=local
XXYY_SKIP_DOCKER=false

# X / Twitter update scraper
# OPTIONAL.
XXYY_X_MAX_PAGES=100
XXYY_X_PAGE_SIZE=40
XXYY_X_REQUEST_DELAY_MS=250

# Documentation media enrichment
# OPTIONAL. auto uses macOS Vision when available, then Tesseract.
MEDIA_OCR_PROVIDER=auto
MEDIA_OCR_LANGS=chi_sim+eng
MEDIA_VIDEO_FRAME_INTERVAL_SECONDS=2
MEDIA_FORCE=false
# Fail docs:enrich:media when any configured video itself cannot be extracted,
# even when its product knowledge is already covered by verified surrounding text.
MEDIA_REQUIRE_ALL=false
# Optional explicit yt-dlp executable. When blank, yt-dlp or uvx is detected.
MEDIA_YTDLP_PATH=
# Optional and intentionally disabled: may prompt for the browser keychain.
MEDIA_YTDLP_COOKIES_FROM_BROWSER=
# Required only for videos without public captions; API key/base URL fall back to OPENAI_*.
TRANSCRIPTION_MODEL=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=

# Agent smoke test
# OPTIONAL.
API_SMOKE_BASE_URL=http://127.0.0.1:3000
API_SMOKE_PRODUCT_QUESTION=XXYY Pro 有哪些权益？
API_SMOKE_BOUNDARY_QUESTION=帮我查一下钱包余额

# Workspace resolution
# OPTIONAL advanced setting. Usually provided by pnpm; normally leave unset.
# INIT_CWD=/absolute/path/to/xxyy-ask
